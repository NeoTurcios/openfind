<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070b13">

    <!-- BACKGROUND LIGHT FLARING EFFECTS FOR ULTRA-PREMIUM LOOK -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/card_background_available"
        android:alpha="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginStart="-100dp" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/card_background_taken"
        android:alpha="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-100dp"
        android:layout_marginEnd="-100dp" />

    <!-- DYNAMIC ISLAND GLASSMORPHIC HEADER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/dynamicIsland"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#00000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/dynamicIslandContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_capsule_background"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/imgIslandLogo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_launcher"
                android:contentDescription="LiberDom Logo" />

            <TextView
                android:id="@+id/txtIslandTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LiberDom"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="10dp" />

            <!-- Animated Status indicator inside the Island -->
            <LinearLayout
                android:id="@+id/islandStatusContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginEnd="12dp">
                
                <ProgressBar
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminateTint="#00e676"/>
                    
                <TextView
                    android:id="@+id/txtIslandStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking..."
                    android:textColor="#00e676"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Language Button (Bypasses Emoji Flag Bug with custom vector flags) -->
            <LinearLayout
                android:id="@+id/btnLangToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#1C2436"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:clickable="true"
                android:focusable="true">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="0dp"
                    app:cardMaxElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardPreventCornerOverlap="false"
                    app:cardUseCompatPadding="false">
                    
                    <ImageView
                        android:id="@+id/imgLangFlag"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/flag_us" />
                </androidx.cardview.widget.CardView>
                    
                <TextView
                    android:id="@+id/txtLangCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textColor="#ffffff"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- CONTENT PANELS CONTAINER -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/dynamicIsland"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationDock"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp">

        <!-- ================= PANEL 1: SINGLE SEARCH ================= -->
        <ScrollView
            android:id="@+id/panelSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- HERO TITLES -->
                <TextView
                    android:id="@+id/txtHeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Encuentra tu próximo dominio"
                    android:textColor="#ffffff"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/txtHeroSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Búsqueda directa e híbrida DNS/WHOIS de bajo nivel sin intermediarios ni cobros."
                    android:textColor="#9ca3af"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="8dp" />

                <!-- INPUT BOX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <EditText
                        android:id="@+id/edtDomainInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/search_input_background"
                        android:hint="Introduce tu dominio... (ej: miweb.com)"
                        android:textColorHint="#4b5563"
                        android:textColor="#ffffff"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:inputType="textUri"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/btnCheck"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Comprobar disponibilidad"
                        android:textColor="#070b13"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@drawable/search_button_background"
                        app:backgroundTint="@null" />

                </LinearLayout>

                <!-- LOADER (In-screen backup, status is also in dynamic island) -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:visibility="gone"
                    android:indeterminateTint="#00e676"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp" />

                <TextView
                    android:id="@+id/txtLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#9ca3af"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="12dp" />

                <!-- RESULTS CARD -->
                <LinearLayout
                    android:id="@+id/cardResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background_default"
                    android:padding="20dp"
                    android:visibility="gone"
                    android:layout_marginTop="24dp">

                    <!-- Card Top Header -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/txtResultDomain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIDOMINIO.COM"
                            android:textColor="#ffffff"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true" />

                        <TextView
                            android:id="@+id/txtResultBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disponible"
                            android:textColor="#00e676"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:background="#1a00e676"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />

                    </RelativeLayout>

                    <!-- Status description message -->
                    <TextView
                        android:id="@+id/txtResultDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¡Felicidades! Este dominio está libre. Puedes registrarlo ahora mismo en tu proveedor favorito."
                        android:textColor="#00e676"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1fffffff"
                        android:layout_marginBottom="16dp" />

                    <!-- Technical Rows -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/lblTechnicalStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Estado Técnico:"
                            android:textColor="#9ca3af"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtTechnicalStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disponible para registro"
                            android:textColor="#ffffff"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/lblServerIp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="IP del Servidor:"
                            android:textColor="#9ca3af"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtServerIp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="142.250.191.46"
                            android:textColor="#ffffff"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowRegistrar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/lblRegistrar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Registrador:"
                            android:textColor="#9ca3af"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtRegistrar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Google LLC"
                            android:textColor="#ffffff"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowCreated"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/lblCreationDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fecha de Creación:"
                            android:textColor="#9ca3af"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtCreationDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1997-09-15"
                            android:textColor="#ffffff"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/lblMethod"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Método de Detección:"
                            android:textColor="#9ca3af"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtMethod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Consulta WHOIS Socket 43"
                            android:textColor="#8b5cf6"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- NEW FEATURE: PREMIUM ACTIONS TOOLBAR (SAVE, EXPORT, SHARE, COPY) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1fffffff"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">

                        <!-- Bookmark/Save Button -->
                        <ImageButton
                            android:id="@+id/btnActionSave"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_star_border"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Guardar"
                            android:layout_marginHorizontal="8dp"
                            app:tint="#FBBF24" />

                        <!-- Export PDF Button -->
                        <ImageButton
                            android:id="@+id/btnActionPdf"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_pdf"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Exportar PDF"
                            android:layout_marginHorizontal="8dp" />

                        <!-- Share Button -->
                        <ImageButton
                            android:id="@+id/btnActionShare"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_share"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Compartir"
                            android:layout_marginHorizontal="8dp"
                            app:tint="#38bdf8" />

                        <!-- Copy Button -->
                        <ImageButton
                            android:id="@+id/btnActionCopy"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_copy"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Copiar"
                            android:layout_marginHorizontal="8dp"
                            app:tint="#a855f7" />

                    </LinearLayout>

                    <!-- NEW FEATURE: REGISTRAR LINKS WITH SLEEK REDIRECT ENLACES -->
                    <TextView
                        android:id="@+id/lblRegisterLinks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Registrar en proveedores sugeridos:"
                        android:textColor="#e5e7eb"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Namecheap suggested button -->
                        <Button
                            android:id="@+id/btnLinkNamecheap"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Namecheap"
                            android:textSize="11sp"
                            android:textColor="#ffffff"
                            android:backgroundTint="#de3700"
                            android:layout_marginHorizontal="4dp"
                            style="@style/Widget.Material3.Button.ElevatedButton" />

                        <!-- Cloudflare suggested button -->
                        <Button
                            android:id="@+id/btnLinkCloudflare"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cloudflare"
                            android:textSize="11sp"
                            android:textColor="#ffffff"
                            android:backgroundTint="#f38020"
                            android:layout_marginHorizontal="4dp"
                            style="@style/Widget.Material3.Button.ElevatedButton" />

                        <!-- GoDaddy suggested button -->
                        <Button
                            android:id="@+id/btnLinkGodaddy"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="GoDaddy"
                            android:textSize="11sp"
                            android:textColor="#ffffff"
                            android:backgroundTint="#00a63f"
                            android:layout_marginHorizontal="4dp"
                            style="@style/Widget.Material3.Button.ElevatedButton" />

                    </LinearLayout>

                </LinearLayout>

                <!-- FOOTER -->
                <TextView
                    android:id="@+id/txtFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Diseñado con amor y código abierto por NeoTurcios\nLicencia No Comercial © 2026"
                    android:textColor="#4b5563"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>
        </ScrollView>

        <!-- ================= PANEL 2: BULK SEARCH ================= -->
        <ScrollView
            android:id="@+id/panelBulk"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txtBulkTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Búsqueda por Lote"
                    android:textColor="#ffffff"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/txtBulkSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Introduce varios dominios (uno por línea) para comprobar disponibilidad simultánea."
                    android:textColor="#9ca3af"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/edtBulkInput"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/search_input_background"
                    android:hint="midominio.com&#10;ejemplo2.net&#10;miweb.org"
                    android:textColorHint="#4b5563"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    android:padding="12dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="16dp"
                    android:scrollbars="vertical" />

                <Button
                    android:id="@+id/btnBulkCheck"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Escanear lote"
                    android:textColor="#070b13"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/search_button_background"
                    android:layout_marginTop="16dp"
                    app:backgroundTint="@null" />

                <!-- Bulk stats panel -->
                <LinearLayout
                    android:id="@+id/containerBulkStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_background_default"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">
                    
                    <TextView
                        android:id="@+id/txtBulkStatChecked"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Listos: 0/0"
                        android:textColor="#ffffff"
                        android:textSize="12sp"
                        android:gravity="center" />
                        
                    <TextView
                        android:id="@+id/txtBulkStatFree"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Libres: 0"
                        android:textColor="#00e676"
                        android:textSize="12sp"
                        android:gravity="center" />
                        
                    <TextView
                        android:id="@+id/txtBulkStatTaken"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Ocupados: 0"
                        android:textColor="#ef4444"
                        android:textSize="12sp"
                        android:gravity="center" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/bulkProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:indeterminate="false"
                    android:progressTint="#00e676"
                    android:visibility="gone"
                    android:layout_marginTop="12dp" />

                <!-- Bulk Results list -->
                <LinearLayout
                    android:id="@+id/containerBulkResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp" />

            </LinearLayout>
        </ScrollView>

        <!-- ================= PANEL 3: GENERATOR ================= -->
        <ScrollView
            android:id="@+id/panelGenerator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txtGeneratorTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Generador de Nombres"
                    android:textColor="#ffffff"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/txtGeneratorSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Genera ideas de dominios increíbles usando palabras clave y diferentes estilos."
                    android:textColor="#9ca3af"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/edtGeneratorKeyword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/search_input_background"
                    android:hint="Ejemplo: cloud, tech, shop, aero"
                    android:textColorHint="#4b5563"
                    android:textColor="#ffffff"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"
                    android:layout_marginTop="16dp" />

                <!-- Selectors for extension -->
                <TextView
                    android:id="@+id/lblSelectTld"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Extensión preferida:"
                    android:textColor="#e5e7eb"
                    android:textSize="13sp"
                    android:layout_marginTop="16dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="8dp">
                    
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <CheckBox
                            android:id="@+id/chkCom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=".com"
                            android:textColor="#ffffff"
                            android:checked="true"
                            android:layout_marginEnd="12dp" />

                        <CheckBox
                            android:id="@+id/chkNet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=".net"
                            android:textColor="#ffffff"
                            android:layout_marginEnd="12dp" />

                        <CheckBox
                            android:id="@+id/chkOrg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=".org"
                            android:textColor="#ffffff"
                            android:layout_marginEnd="12dp" />

                        <CheckBox
                            android:id="@+id/chkIo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=".io"
                            android:textColor="#ffffff"
                            android:layout_marginEnd="12dp" />

                        <CheckBox
                            android:id="@+id/chkApp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=".app"
                            android:textColor="#ffffff" />
                    </LinearLayout>
                </HorizontalScrollView>

                <Button
                    android:id="@+id/btnGenerateNames"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Generar Ideas"
                    android:textColor="#070b13"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/search_button_background"
                    android:layout_marginTop="24dp"
                    app:backgroundTint="@null" />

                <!-- Generator Results list -->
                <LinearLayout
                    android:id="@+id/containerGeneratorResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp" />

            </LinearLayout>
        </ScrollView>

        <!-- ================= PANEL 4: SAVED & HISTORY ================= -->
        <ScrollView
            android:id="@+id/panelSaved"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txtSavedTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mi Biblioteca"
                    android:textColor="#ffffff"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Custom Elegant Tab selector for Saved vs History -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/glass_capsule_background"
                    android:padding="4dp"
                    android:layout_marginTop="16dp">
                    
                    <Button
                        android:id="@+id/btnTabSaved"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Guardados"
                        android:textSize="12sp"
                        android:textColor="#ffffff"
                        android:backgroundTint="#243049"
                        style="@style/Widget.Material3.Button.ElevatedButton" />
                        
                    <Button
                        android:id="@+id/btnTabHistory"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Historial"
                        android:textSize="12sp"
                        android:textColor="#9CA3AF"
                        android:backgroundTint="#00000000"
                        style="@style/Widget.Material3.Button.TextButton" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/lblListCount"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="0 Dominios"
                        android:textColor="#9ca3af"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnClearList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Limpiar"
                        android:textSize="11sp"
                        android:textColor="#ef4444"
                        style="@style/Widget.Material3.Button.TextButton" />
                </LinearLayout>

                <!-- History / Saved items list -->
                <LinearLayout
                    android:id="@+id/containerSavedResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- FLOATING DOCK BOTTOM NAVIGATION BAR (GLASSMORPHIC DOCK LOOK) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomNavigationDock"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#00000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/glass_capsule_background"
            android:paddingHorizontal="8dp">

            <!-- TAB 1: SEARCH -->
            <LinearLayout
                android:id="@+id/navTabSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:id="@+id/imgTabSearch"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="#00e676" />
                    
                <TextView
                    android:id="@+id/txtTabSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buscar"
                    android:textColor="#00e676"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- TAB 2: BULK -->
            <LinearLayout
                android:id="@+id/navTabBulk"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:id="@+id/imgTabBulk"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_bulk"
                    app:tint="#6B7280" />
                    
                <TextView
                    android:id="@+id/txtTabBulk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Por lote"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- TAB 3: GENERATOR -->
            <LinearLayout
                android:id="@+id/navTabGenerator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:id="@+id/imgTabGenerator"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_generator"
                    app:tint="#6B7280" />
                    
                <TextView
                    android:id="@+id/txtTabGenerator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generador"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- TAB 4: SAVED / LIBRARY -->
            <LinearLayout
                android:id="@+id/navTabSaved"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                
                <ImageView
                    android:id="@+id/imgTabSaved"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_star"
                    app:tint="#6B7280" />
                    
                <TextView
                    android:id="@+id/txtTabSaved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Biblioteca"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
